# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Network
SERVER_ADDRESS=127.0.0.1
SERVER_PORT=8081
SERVER_FORWARD_HEADERS_STRATEGY=framework

# Logging
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO

# Match tuning
SOCIAL_HAZARD_MIN_PLAYERS=2
SOCIAL_HAZARD_MAX_PLAYERS=4
SOCIAL_HAZARD_DEFAULT_TARGET_SCORE=5
SOCIAL_HAZARD_MIN_TARGET_SCORE=3
SOCIAL_HAZARD_MAX_TARGET_SCORE=10
SOCIAL_HAZARD_DUEL_HAND_SIZE=5
SOCIAL_HAZARD_CLASSIC_HAND_SIZE=7
SOCIAL_HAZARD_CLEANUP_INTERVAL_MS=60000
SOCIAL_HAZARD_STALE_ROOM_THRESHOLD=PT20M

# Origins
SOCIAL_HAZARD_ALLOWED_ORIGIN_PATTERNS=https://api.fluxcloud.dev

# JVM
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC
