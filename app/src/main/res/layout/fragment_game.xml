<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/space_20"
    android:paddingTop="@dimen/space_8"
    android:paddingBottom="@dimen/space_16">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Widget.SocialHazard.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:navigationContentDescription="@string/navigation_back"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:title="@string/game_prompt" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.SocialHazard.BlackCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_12">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="204dp"
            android:orientation="vertical"
            android:padding="@dimen/space_20">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/solo_showcase_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/demo_mode_eyebrow"
                    android:textAppearance="@style/TextAppearance.SocialHazard.Eyebrow"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/card_type_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/black_card_label"
                    android:textAppearance="@style/TextAppearance.SocialHazard.Eyebrow" />
            </LinearLayout>

            <TextView
                android:id="@+id/prompt_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_14"
                android:textAppearance="@style/TextAppearance.SocialHazard.Headline" />

            <TextView
                android:id="@+id/judge_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_14"
                android:textAppearance="@style/TextAppearance.SocialHazard.SectionLabel" />

            <TextView
                android:id="@+id/prompt_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:textAppearance="@style/TextAppearance.SocialHazard.Body" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_16"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/hand_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Your hand"
            android:textAppearance="@style/TextAppearance.SocialHazard.Title" />

        <TextView
            android:id="@+id/hand_type_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/blue_cards_label"
            android:textAppearance="@style/TextAppearance.SocialHazard.Eyebrow" />
    </LinearLayout>

    <TextView
        android:id="@+id/answer_list_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_6"
        android:textAppearance="@style/TextAppearance.SocialHazard.Body"
        android:visibility="gone"
        tools:text="Refreshing your private hand from the server."
        tools:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/answer_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_10"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:layoutAnimation="@anim/layout_staggered_soft"
        android:nestedScrollingEnabled="true"
        android:paddingBottom="@dimen/space_4"
        tools:itemCount="6"
        tools:listitem="@layout/item_answer_card" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.SocialHazard.PanelCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_10">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_16">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="One move"
                android:textAppearance="@style/TextAppearance.SocialHazard.Eyebrow" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/submit_button"
                style="@style/Widget.SocialHazard.PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:text="@string/submit_answer" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
