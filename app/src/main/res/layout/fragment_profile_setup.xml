<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="@dimen/space_24"
    android:paddingVertical="@dimen/space_24">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/avatar_top_guide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.12" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/form_top_guide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.64" />

    <TextView
        android:id="@+id/avatar_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/profile_setup_title"
        android:textAppearance="@style/TextAppearance.SocialHazard.Eyebrow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/avatar_top_guide" />

    <TextView
        android:id="@+id/avatar_body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_12"
        android:gravity="center"
        android:text="@string/profile_setup_body"
        android:textAppearance="@style/TextAppearance.SocialHazard.Body"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/avatar_title" />

    <ImageButton
        android:id="@+id/left_avatar_button"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:adjustViewBounds="true"
        android:background="@android:color/transparent"
        android:contentDescription="@string/avatar_previous"
        android:scaleType="centerInside"
        android:src="@drawable/avatar_nav_left"
        app:layout_constraintBottom_toBottomOf="@id/avatar_image"
        app:layout_constraintEnd_toStartOf="@id/avatar_image"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/avatar_image" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/avatar_image"
        android:layout_width="176dp"
        android:layout_height="176dp"
        android:layout_marginHorizontal="@dimen/space_20"
        android:layout_marginTop="@dimen/space_24"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toStartOf="@id/right_avatar_button"
        app:layout_constraintStart_toEndOf="@id/left_avatar_button"
        app:layout_constraintTop_toBottomOf="@id/avatar_body"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.SocialHazard.Circle"
        app:strokeColor="@color/sh_primary"
        app:strokeWidth="2dp" />

    <ImageButton
        android:id="@+id/right_avatar_button"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:adjustViewBounds="true"
        android:background="@android:color/transparent"
        android:contentDescription="@string/avatar_next"
        android:scaleType="centerInside"
        android:src="@drawable/avatar_nav_right"
        app:layout_constraintBottom_toBottomOf="@id/avatar_image"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/avatar_image"
        app:layout_constraintTop_toTopOf="@id/avatar_image" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.SocialHazard.PanelCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/form_top_guide">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_24">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_setup_nickname_label"
                android:textAppearance="@style/TextAppearance.SocialHazard.Eyebrow" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/nickname_input_layout"
                style="@style/Widget.SocialHazard.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:hint="@string/profile_setup_nickname_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:maxLines="1"
                    android:textColor="@color/sh_text_primary"
                    android:textColorHint="@color/sh_text_muted" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/continue_button"
                style="@style/Widget.SocialHazard.PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                android:text="@string/profile_setup_continue" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
