<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:paddingHorizontal="@dimen/space_20"
    android:paddingTop="@dimen/space_12"
    android:paddingBottom="@dimen/space_32">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:animateLayoutChanges="true"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/Widget.SocialHazard.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:navigationContentDescription="@string/navigation_back"
            app:navigationIcon="@drawable/ic_arrow_back_24"
            app:title="@string/demo_title" />

        <TextView
            android:id="@+id/locked_notice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_20"
            android:text="@string/demo_locked"
            android:textAppearance="@style/TextAppearance.SocialHazard.Body"
            android:textColor="@color/sh_error"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/demo_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SocialHazard.BlackCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_24">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/demo_mode_eyebrow"
                            android:textAppearance="@style/TextAppearance.SocialHazard.Eyebrow" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/black_card_label"
                            android:textAppearance="@style/TextAppearance.SocialHazard.Eyebrow" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_16"
                        android:text="@string/demo_mode_headline"
                        android:textAppearance="@style/TextAppearance.SocialHazard.Headline" />

                    <TextView
                        android:id="@+id/demo_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:background="@drawable/bg_room_code"
                        android:paddingHorizontal="@dimen/space_12"
                        android:paddingVertical="@dimen/space_4"
                        android:text="@string/demo_status_idle"
                        android:textColor="@color/sh_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_16"
                        android:text="@string/demo_body"
                        android:textAppearance="@style/TextAppearance.SocialHazard.Body" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_20"
                        android:orientation="horizontal">

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.SocialHazard.InfoChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/demo_chip_offline" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/start_walkthrough_button"
                        style="@style/Widget.SocialHazard.PrimaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_20"
                        android:text="@string/demo_start_walkthrough" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SocialHazard.PanelCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_24">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/demo_shortcuts_label"
                        android:textAppearance="@style/TextAppearance.SocialHazard.Eyebrow" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:text="@string/demo_shortcuts_body"
                        android:textAppearance="@style/TextAppearance.SocialHazard.Body" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/to_lobby_button"
                        style="@style/Widget.SocialHazard.SecondaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_20"
                        android:text="@string/go_to_lobby" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/to_game_button"
                        style="@style/Widget.SocialHazard.SecondaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:text="@string/go_to_game" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/to_judge_button"
                        style="@style/Widget.SocialHazard.SecondaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:text="@string/go_to_judge" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/to_result_button"
                        style="@style/Widget.SocialHazard.SecondaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:text="@string/go_to_result" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/to_scoreboard_button"
                        style="@style/Widget.SocialHazard.SecondaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:text="@string/go_to_scoreboard" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

</androidx.core.widget.NestedScrollView>
