<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="20dp" />
            <solid android:color="@color/sh_surface_inset" />
            <stroke
                android:width="1dp"
                android:color="@color/sh_outline_soft" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp">
        <shape>
            <corners android:radius="20dp" />
            <gradient
                android:angle="270"
                android:endColor="@android:color/transparent"
                android:startColor="@color/sh_overlay_soft" />
        </shape>
    </item>
</layer-list>
