<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="@dimen/card_radius" />
            <gradient
                android:angle="315"
                android:endColor="@color/sh_surface_black_card_alt"
                android:startColor="@color/sh_surface_black_card" />
            <stroke
                android:width="1dp"
                android:color="@color/sh_outline_black_card" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape>
            <corners android:radius="@dimen/card_radius" />
            <gradient
                android:angle="270"
                android:endColor="#0AFFFFFF"
                android:startColor="#1EFFFFFF" />
        </shape>
    </item>

    <item
        android:left="10dp"
        android:top="12dp"
        android:right="10dp"
        android:bottom="12dp">
        <shape>
            <corners android:radius="@dimen/card_radius" />
            <gradient
                android:angle="0"
                android:centerColor="#0EFFFFFF"
                android:endColor="#00FFFFFF"
                android:startColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
